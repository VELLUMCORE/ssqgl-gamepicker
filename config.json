{
  "seed_policy": {
    "template": "{date}|{phrase}",
    "phrase": "AM1224"
  },
  "snapshot": {
    "shortlist_size": 2000,
    "seed_suffix": "|snapshot",
    "source_mix": {
      "steam": 0.75,
      "gog": 0.25
    }
  },
  "sources": {
    "steam": {
      "enabled": true,
      "discovery": {
        "cc": "KR",
        "l": "koreana",
        "target_appids": 8000,
        "channels": [
          {
            "kind": "featuredcategories",
            "bucket": "top_sellers",
            "take": 500
          },
          {
            "kind": "featuredcategories",
            "bucket": "new_releases",
            "take": 500
          },
          {
            "kind": "featuredcategories",
            "bucket": "specials",
            "take": 500
          },
          {
            "kind": "search",
            "filter": "topsellers",
            "start_mode": "sequential",
            "pages": 24,
            "count": 50,
            "take": 1200
          },
          {
            "kind": "search",
            "filter": "popularnew",
            "start_mode": "sequential",
            "pages": 12,
            "count": 50,
            "take": 600
          },
          {
            "kind": "search",
            "filter": "popular",
            "start_mode": "random_deep",
            "pages": 24,
            "count": 50,
            "take": 1200,
            "max_start_blocks": 300
          }
        ],
        "retry": {
          "max_attempts": 4,
          "base_sleep_sec": 1.2,
          "max_sleep_sec": 20.0,
          "jitter_sec": 0.4
        },
        "cache_ttl_hours": 336,
        "content_safety": {
          "max_required_age": 17,
          "exclude_content_descriptors": [
            1,
            3,
            4
          ]
        },
        "request_min_interval_sec": 0.15,
        "empty_page_break": 2,
        "stop_channel_on_rate_limit": true,
        "random_deep_max_pages": 24
      },
      "enrich": {
        "request_min_interval_sec": 1.6,
        "retry": {
          "max_attempts": 4,
          "base_sleep_sec": 1.2,
          "max_sleep_sec": 20.0,
          "jitter_sec": 0.4
        }
      }
    },
    "gog": {
      "enabled": true,
      "discovery": {
        "target_products": 4000,
        "sorts": [
          "popularity",
          "rating",
          "date"
        ],
        "page_mode": "random",
        "limit": 48,
        "max_pages_tried": 400,
        "random_page_max": 200,
        "retry": {
          "max_attempts": 6,
          "base_sleep_sec": 1.0,
          "max_sleep_sec": 30.0
        },
        "cache_ttl_hours": 336
      }
    },
    "local": {
      "enabled": false,
      "path": null
    }
  },
  "filters": {
    "exclude_tags": [
      "Horror"
    ],
    "exclude_app_types": [
      "DLC",
      "Soundtrack",
      "Tool"
    ]
  },
  "quality_gate": {
    "explore_mass": 0.2,
    "steam": {
      "wilson_lb_min": 0.75,
      "min_reviews": 200
    },
    "metascore_min": 70
  },
  "stratify": {
    "popularity_bins": 3,
    "genre_floor_eps": 0.02
  },
  "weights": {
    "wQ": 0.55,
    "wS": 0.3,
    "wN": 0.1,
    "wC": 0.05,
    "temperature": 0.7
  }
}